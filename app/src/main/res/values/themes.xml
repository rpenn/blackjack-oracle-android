<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BlackjackOracle" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- API 27+: theme attribute is silently ignored on older devices (where
             a dark nav bar is the default anyway, matching `false`). Marked so
             lintVitalRelease — which is required for release builds — passes. -->
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>
</resources>
